    {
      "parameters": {
        "jsCode": "const data = $input.all()[0].json;\nconst articles = data.articles || [];\nconst stats = data.prisma_stats || data.stats || {};\nconst outputFolder = data.output_folder || '/desktop/review ultralab';\n\nconst sorted = [...articles].sort((a, b) => (b.score || 0) - (a.score || 0));\nconst included = sorted.filter(a => a.screening_decision === 'Include');\nconst maybe = sorted.filter(a => a.screening_decision === 'Maybe');\nconst excluded = sorted.filter(a => a.screening_decision === 'Exclude');\n\nconst screening_summary = sorted.map(a => ({\n  title: a.title || '',\n  authors: Array.isArray(a.authors) ? a.authors.join('; ') : '',\n  year: a.year || '',\n  journal: a.journal || '',\n  doi: a.doi || '',\n  abstract: (a.abstract || '').substring(0, 500),\n  source: a.source || '',\n  score: a.score !== undefined ? a.score : 50,\n  cluster: a.cluster_label || '',\n  decision: a.screening_decision || 'Maybe',\n  color: a.screening_color || 'orange',\n  reason: a.screening_reason || ''\n}));\n\nreturn [{\n  json: {\n    status: 'completed',\n    output_folder: outputFolder,\n    prisma_stats: {\n      total: stats.total || articles.length,\n      included: stats.included || included.length,\n      excluded: stats.excluded || excluded.length,\n      maybe: stats.maybe || maybe.length\n    },\n    screening_summary\n  }\n}];",
        "mode": "runOnceForAllItems"
      },
