    {
      "parameters": {
        "jsCode": "// Parse Query v3 - supporte equation PubMed personnalisee de l'utilisateur\nconst data = $input.all()[0].json;\nconst question = data.question || '';\nconst criteria = data.criteria || '';\nconst prefilter_enabled = data.prefilter_enabled !== undefined ? data.prefilter_enabled : true;\nconst prefilter_count = parseInt(data.prefilter_count) || 300;\nconst max_results = parseInt(data.max_results) || 1000;\n// INCLUDE_EXTRACTION_PREDATORY_v1 - flags v0.2.6\nconst include_extraction = data.include_extraction === true || data.include_extraction === 'true';\nconst include_predatory_scan = data.include_predatory_scan === true || data.include_predatory_scan === 'true';\n\nconst customPubmed = (data.custom_pubmed_query || '').trim();\n  // DIRECT_ARTICLES_BYPASS_v2 - Extract Params (Set) ne propage pas direct_articles ;\n  // on le lit directement depuis le body du webhook 'User Input' (source de verite).\n  let _da = data.direct_articles;\n  if (!Array.isArray(_da)) {\n    try { var _wb = $('User Input').first().json.body || $('User Input').first().json; _da = _wb ? _wb.direct_articles : null; } catch (e) { _da = null; }\n  }\n  const direct_articles = Array.isArray(_da) ? _da : null;\n\n\n\nlet pubmed_query = question;\nlet openalex_query = question;\nlet crossref_query = question;\n\n// Helper: derive simple keyword query from a PubMed boolean equation\nfunction derivePlainQuery(pmQuery) {\n  if (!pmQuery) return question;\n  // strip MeSH/field tags like [MeSH Terms], [tiab], [Title/Abstract]\n  let q = pmQuery.replace(/\\[[^\\]]*\\]/g, ' ');\n  // remove parentheses\n  q = q.replace(/[()]/g, ' ');\n  // remove quotes\n  q = q.replace(/[\"']/g, ' ');\n  // collapse boolean operators (keep AND/OR meaning by joining with space)\n  q = q.replace(/\\b(AND|OR|NOT)\\b/gi, ' ');\n  // collapse multiple spaces\n  q = q.replace(/\\s+/g, ' ').trim();\n  return q || question;\n}\n\nif (customPubmed) {\n  // === MODE EQUATION PERSONNALISEE ===\n  pubmed_query = customPubmed;\n  openalex_query = derivePlainQuery(customPubmed);\n  crossref_query = derivePlainQuery(customPubmed);\n  console.log('Parse Query: USING CUSTOM PUBMED EQUATION');\n  console.log('  PubMed: ' + pubmed_query.substring(0, 100));\n  console.log('  OpenAlex (derived): ' + openalex_query.substring(0, 80));\n} else {\n  // === MODE GENERATION OLLAMA ===\n  try {\n    const raw = data.ollama_response || '';\n    const parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;\n    if (parsed.pubmed_query) pubmed_query = parsed.pubmed_query;\n    if (parsed.openalex_query) openalex_query = parsed.openalex_query;\n    if (parsed.crossref_query) crossref_query = parsed.crossref_query;\n    console.log('Parse Query: Ollama-generated queries extracted');\n  } catch(e) {\n    console.log('Parse Query: Ollama parse error, using question as fallback - ' + e.message);\n  }\n}\n\n// PER_BASE_QUERY_PIPELINE_v1 - traduction deterministe par base depuis l'equation PubMed\nfunction buildBaseQueries(pmq) {\n  var raw = (pmq || '').trim();\n  var s = raw.replace(/\\(\\s*\"?\\d{4}\"?\\s*\\[[^\\]]*\\]\\s*:\\s*\"?\\d{4}\"?\\s*\\[[^\\]]*\\]\\s*\\)/gi, ' ');\n  var bool = s.replace(/\\[[^\\]]*\\]/g, ' ').replace(/\\b(and|or|not)\\b/g, function(m){ return m.toUpperCase(); }).replace(/\\(\\s*\\)/g, ' ').replace(/\\s+/g, ' ').trim().replace(/^\\s*(AND|OR|NOT)\\b/, '').replace(/\\b(AND|OR|NOT)\\s*$/, '').trim();\n  var free = bool.replace(/[()]/g, ' ').replace(/\\b(AND|OR|NOT)\\b/g, ' ').replace(/\\s+/g, ' ').trim();\n  return { boolean: bool, freetext: free };\n}\nvar _bq = buildBaseQueries(pubmed_query);\nopenalex_query = _bq.freetext;\ncrossref_query = _bq.freetext;\nvar doaj_query = _bq.boolean;\nvar base_query = _bq.boolean;\nvar lens_query = _bq.boolean;\nvar semantic_query = _bq.freetext;\nvar __dm = (pubmed_query||'').match(/\"?(\\d{4})\"?\\s*\\[[^\\]]*\\]\\s*:\\s*\"?(\\d{4})\"?\\s*\\[[^\\]]*\\]/i);\nvar date_start = __dm ? __dm[1] : '';\nvar date_end = __dm ? __dm[2] : '';\n\nconst topic = question.substring(0, 50).replace(/[^a-zA-Z0-9 ]/g, '').trim();\nconst folderName = (topic || 'untitled') + ' review ultralab';\nconst folderPath = '/desktop/' + folderName;\n\nconst skip_ranking = data.skip_ranking || false;\nconst skip_clustering = data.skip_clustering || false;\nconst skip_screening = data.skip_screening || false;\nconst skip_pdf = data.skip_pdf || false;\nconst output_format = ((data.output_format || 'ris') + '').toLowerCase();\n\nconsole.log('Parse Query output: question=' + question.substring(0, 40) + ', folder=' + folderName);\nconsole.log('Skip flags: ranking=' + skip_ranking + ' clustering=' + skip_clustering + ' screening=' + skip_screening + ' pdf=' + skip_pdf);\n\nreturn [{ json: {\n    direct_articles: direct_articles,\n\n  question,\n  criteria,\n  search_query: openalex_query,\n  pubmed_query,\n  openalex_query,\n  crossref_query,\n  doaj_query,\n  base_query,\n  lens_query,\n  semantic_query,\n  date_start,\n  date_end,\n  output_folder: folderPath,\n  folder_name: folderName,\n  prefilter_enabled,\n  prefilter_count,\n  max_results,\n  skip_ranking,\n  skip_clustering,\n  skip_screening,\n  skip_pdf,\n  include_extraction,\n  include_predatory_scan,\n  custom_query_used: !!customPubmed,\n  output_format\n}}];",
        "mode": "runOnceForAllItems"
      },
