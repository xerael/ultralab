      "parameters": {
        "jsCode": "// === RESPOND IMMEDIATELY (async webhook pattern) ===\n// Envoie une reponse rapide au browser pour qu'il puisse fermer la connexion HTTP\n// et basculer sur le polling. Le workflow continue en parallele.\nconst input = $input.first().json;\nconst body = input.body || input;\nconst question = (body.question || '').toString();\nconst now = new Date();\nconst pad = n => String(n).padStart(2, '0');\nconst timestamp = now.getFullYear() + pad(now.getMonth()+1) + pad(now.getDate()) + '-' + pad(now.getHours()) + pad(now.getMinutes());\n// Le pipeline ecrit son dossier dans /desktop/<topic> review ultralab/\nconst topic = question.substring(0, 50).replace(/[^a-zA-Z0-9 ]/g, '').trim();\nconst expectedFolder = '/desktop/' + (topic || 'untitled') + ' review ultralab';\nreturn [{\n  json: {\n    started: true,\n    async: true,\n    mode: 'pipeline',\n    expected_folder: expectedFolder,\n    started_at: now.toISOString(),\n    message: 'Pipeline systematique demarre en background sur n8n. Le browser doit poller /api/last-result pour le resultat final.'\n  }\n}];",
        "mode": "runOnceForAllItems"
      },
