    {
      "parameters": {
        "jsCode": "// Pipeline Predatory Scan - appelle Flask /api/predatory-check\n// Idempotent et defensif : si Flask down, retourne les articles non scores\nconst items = $input.all();\nconst articles = items.map(i => i.json);\nconsole.log('[Predatory Scan Pipeline] ' + articles.length + ' articles a scanner');\n\ntry {\n  const resp = await this.helpers.httpRequest({\n    method: 'POST',\n    url: 'http://host.docker.internal:8080/api/predatory-check',\n    body: JSON.stringify({ articles: articles, do_external_apis: true }),\n    headers: { 'Content-Type': 'application/json' },\n    timeout: 1800000,\n    json: true,\n  });\n  if (resp && resp.success && Array.isArray(resp.scanned)) {\n    return resp.scanned.map(a => ({ json: a }));\n  }\n  console.log('[Predatory Scan] reponse Flask inattendue, articles non scores');\n  return articles.map(a => ({ json: { ...a, _predatory_error: 'invalid flask response' } }));\n} catch (e) {\n  console.log('[Predatory Scan] erreur : ' + (e.message || e));\n  return articles.map(a => ({ json: { ...a, _predatory_error: (e.message || String(e)) } }));\n}\n",
